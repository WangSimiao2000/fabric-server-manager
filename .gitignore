# ===== GameFile: 默认全部忽略，反向保留需要的文件 =====
GameFile/*
!GameFile/config/
!GameFile/eula.txt
!GameFile/server.properties.example

# config 下的运行时 / 缓存文件仍然忽略
GameFile/config/spark/tmp/
GameFile/config/spark/tmp-client/
GameFile/config/EasyAuth/backup/
GameFile/config/*.backup*
GameFile/config/chunky/tasks/
GameFile/config/luckperms/translations/
GameFile/config/luckperms/editor-keystore.json

# ===== 项目级忽略 =====
config.json
backups/
.cache/
.watchdog/
.mc.lock
__pycache__/
